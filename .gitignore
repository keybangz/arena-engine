*.zip
*.tar.gz
*.tar.xz
*.7z
*.rar

# AppImage
*.AppImage
*.AppDir/

# Flatpak
.flatpak-builder/
*.flatpak

# Installers
*.deb
*.rpm
*.msi

# ==============================================================================
# Secrets & Credentials (NEVER commit these)
# ==============================================================================

# API keys
*.key
*.pem
*.p12
secrets/
credentials/

# Environment files
.env
.env.local
.env.*.local

# ==============================================================================
# Misc
# ==============================================================================

# Backup files
*.bak
*.backup
*.old
*.orig

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Debug dumps
*.dmp
core
core.*

# Local overrides (for developer-specific ignores)
.gitignore.local
